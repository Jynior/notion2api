# ==========================================
# Notion-AI Configuration Template
# Copy this file to .env and fill in actual values
# ==========================================

# ----------------------------------------------------------
# 1. Core Credentials: Notion Account Pool (JSON Array Format)
# ----------------------------------------------------------
# Must include: token_v2, space_id, user_id
# Multiple accounts enable load balancing and rate-limit rotation
#
# Recommended: run `python login.py` to launch Chrome, capture the active
# Notion session locally, and update accounts.json/.env automatically.
#
# Legacy manual fallback: copy token_v2 from DevTools, then run
# scripts/extract_notion_info.js in the browser console to get the other fields.
# ----------------------------------------------------------
NOTION_ACCOUNTS='[{"profile_name":"default","token_v2":"your_token","space_id":"your_space","user_id":"your_uid","space_view_id":"your_view","user_name":"your_name","user_email":"your_email"}]'

# ----------------------------------------------------------
# 2. FastAPI Service & Security
# ----------------------------------------------------------
# API_KEY: Bearer token required for /v1/chat/completions
# Leave empty to disable auth (not recommended for production)
API_KEY=

# HOST: bind address. 0.0.0.0 allows LAN access
HOST=0.0.0.0

# ALLOWED_ORIGINS: comma-separated CORS origins.
# Use "*" to allow all (not recommended for production).
ALLOWED_ORIGINS=*

# PORT: service listen port (container internal; host port in docker-compose.yml)
PORT=8000

# APP_MODE: runtime mode
# - standard: full context, thinking & search, no database (default, recommended)
# - lite: single-turn Q&A, no memory, no database
# - heavy: full session management, requires SQLite + optional SILICONFLOW_API_KEY
APP_MODE=standard

# ----------------------------------------------------------
# 3. Docker Configuration
# ----------------------------------------------------------
# HOST_PORT: host-published port (docker-compose)
HOST_PORT=8000

# ----------------------------------------------------------
# 4. Data Persistence (SQLite)
# ----------------------------------------------------------
# DB_PATH: chat history database path
# In Docker, docker-compose.yml overrides this to /app/data/conversations.db
# Local dev: ./data/conversations.db
DB_PATH=./data/conversations.db

# ----------------------------------------------------------
# 5. Advanced Configuration (Optional)
# ----------------------------------------------------------
# SILICONFLOW_API_KEY: optional summarizer backend for heavy mode
SILICONFLOW_API_KEY=

# NOTION_CLIENT_VERSION: override Notion client version header if upstream changes
# NOTION_CLIENT_VERSION=23.13.20260228.0625

# NOTION_URL: Notion site base URL (mirror / reverse proxy). Default official site.
# NOTION_URL=https://www.notion.so
#
# NOTION_DOMAIN: cookie domain used by login.py. Default: www.notion.so
# NOTION_DOMAIN=www.notion.so

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Timezone
TZ=UTC
